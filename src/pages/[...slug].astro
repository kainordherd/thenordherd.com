---
export const prerender = true

import { render } from 'astro:content'
import PageLayout from '@/layouts/PageLayout.astro'
import PostLayout from '@/layouts/PostLayout.astro'
import IndexLayout from '@/layouts/IndexLayout.astro'
import type { PostRenderFrontmatter } from '@/types'
import {
  getContentDescription,
  getPublishedContentSlugs,
  markdownAlternateLink,
  markdownResponse,
  notAcceptableResponse,
  resolveContentRoute,
  shouldServeMarkdown
} from '@/utils/markdown-content'
import { preferredContentType } from '@/utils/content-negotiation'
import { themeConfig } from '@/config'

export async function getStaticPaths() {
  const slugs = await getPublishedContentSlugs()

  return slugs.map((slug) => ({ params: { slug } }))
}

const resolvedRoute = await resolveContentRoute(Astro.params.slug)

if (!resolvedRoute) {
  Astro.response.status = 404
  Astro.response.statusText = 'Not Found'
} else {
  const preferredType = Astro.locals.preferredContentType ?? preferredContentType(Astro.request.headers.get('Accept'))

  if (preferredType === null && !resolvedRoute.markdownExtension) {
    return notAcceptableResponse()
  }

  if (shouldServeMarkdown(resolvedRoute, preferredType)) {
    return markdownResponse(resolvedRoute)
  }

  Astro.response.headers.append('Link', markdownAlternateLink(resolvedRoute))
}

const route = resolvedRoute?.route
const rendered = route ? await render(route.entry) : null
const Content = rendered?.Content
const { readingTime, toc = [] } = (rendered?.remarkPluginFrontmatter ?? {}) as PostRenderFrontmatter
const description = route ? getContentDescription(route) : 'Not Found'
---

{
  !route || !Content ? (
    <IndexLayout title={`404 - ${themeConfig.site.title}`} description="Not Found" noindex omitCanonical>
      <p class="error-container" style="color: var(--text-secondary);">
        Page Not Found...
      </p>
    </IndexLayout>
  ) : route.kind === 'post' ? (
    <PostLayout
      title={route.entry.data.title}
      description={description}
      pubDate={route.entry.data.pubDate}
      image={route.entry.data.image}
      readingTime={readingTime}
      toc={toc}
    >
      <Content />
    </PostLayout>
  ) : (
    <PageLayout title={route.entry.data.title} description={description} image={route.entry.data.image} toc={toc}>
      <Content />
    </PageLayout>
  )
}
