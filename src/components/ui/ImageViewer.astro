<div
  id="image-viewer"
  class="image-viewer"
  role="dialog"
  aria-modal="true"
  aria-label="Image preview"
  aria-hidden="true"
>
  <button type="button" class="image-viewer-close" aria-label="Close image preview">&times;</button>
  <img id="image-viewer-img" src="" alt="" />
</div>

<script>
  let imageViewerPreviousFocus: HTMLElement | null = null
  let imageViewerObserver: MutationObserver | null = null

  function initImageViewer() {
    const viewer = document.getElementById('image-viewer')
    const viewerImg = document.getElementById('image-viewer-img') as HTMLImageElement
    const closeButton = viewer?.querySelector('.image-viewer-close') as HTMLButtonElement

    if (!viewer || !viewerImg || viewerImg.tagName !== 'IMG' || !closeButton) return

    // Display image in fullscreen viewer overlay
    function showImage(src: string, alt?: string) {
      imageViewerPreviousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null
      if (viewerImg && src) {
        viewerImg.src = src
        viewerImg.alt = alt || ''
      }
      viewer!.setAttribute('aria-hidden', 'false')
      // Show visibility first
      viewer!.style.visibility = 'visible'
      void viewer!.offsetWidth
      viewer!.classList.add('active')
      document.body.classList.add('image-viewer-open')
      document.body.style.overflow = 'hidden'
      document.body.dataset.scrollY = window.scrollY.toString()
      viewer!.style.cursor = 'auto'
      closeButton.focus({ preventScroll: true })
      setTimeout(() => {
        viewer!.style.cursor = ''
      }, 10)
    }

    // Hide the image viewer and restore page scroll
    function hideImage() {
      viewer!.classList.remove('active')
      viewer!.setAttribute('aria-hidden', 'true')
      document.body.classList.remove('image-viewer-open')
      document.body.style.overflow = ''
      imageViewerPreviousFocus?.focus({ preventScroll: true })
      imageViewerPreviousFocus = null
    }

    // Bind click events to images with data-preview="true" attribute
    function bindImageClickEvents() {
      const previewImages = document.querySelectorAll('img[data-preview="true"]')
      previewImages.forEach((img) => {
        const imgElement = img as HTMLImageElement
        if (imgElement.dataset.previewBound) return
        imgElement.dataset.previewBound = 'true'
        imgElement.style.cursor = 'pointer'
        imgElement.tabIndex = 0
        imgElement.setAttribute('role', 'button')
        imgElement.setAttribute(
          'aria-label',
          imgElement.alt ? `Open image preview: ${imgElement.alt}` : 'Open image preview'
        )
        imgElement.addEventListener('click', (e) => {
          e.preventDefault()
          const target = e.target as HTMLImageElement
          showImage(target.src, target.alt || '')
        })
        imgElement.addEventListener('keydown', (e) => {
          if (e.key !== 'Enter' && e.key !== ' ') return
          e.preventDefault()
          showImage(imgElement.src, imgElement.alt || '')
        })
      })
    }

    if (!viewer.dataset.viewerBound) {
      viewer.dataset.viewerBound = 'true'

      // Hide and clear image after transition ends
      viewer.addEventListener('transitionend', (e) => {
        if (e.propertyName === 'opacity' && !viewer.classList.contains('active')) {
          viewer.style.visibility = 'hidden'
          if (viewerImg) {
            viewerImg.src = ''
            viewerImg.alt = ''
          }
          viewer.style.cursor = 'auto'
          setTimeout(() => {
            viewer.style.cursor = ''
          }, 10)
        }
      })

      viewer.addEventListener('click', (e) => {
        const target = e.target
        if (target === viewer || (target instanceof Element && target.closest('.image-viewer-close'))) {
          hideImage()
        }
      })

      // Prevent touch scroll in image viewer
      viewer.addEventListener(
        'touchmove',
        (e) => {
          if (viewer.classList.contains('active')) {
            e.preventDefault()
          }
        },
        { passive: false }
      )

      document.addEventListener('keydown', (e) => {
        if (!viewer.classList.contains('active')) return

        if (e.key === 'Escape') {
          hideImage()
          return
        }

        if (e.key === 'Tab') {
          e.preventDefault()
          closeButton.focus({ preventScroll: true })
        }
      })
    }

    bindImageClickEvents()

    // Observe only the content area instead of the entire body
    const contentArea =
      document.querySelector('.prose') || document.querySelector('.content') || document.querySelector('article')
    if (contentArea) {
      imageViewerObserver?.disconnect()
      imageViewerObserver = new MutationObserver(() => {
        bindImageClickEvents()
      })

      imageViewerObserver.observe(contentArea, {
        childList: true,
        subtree: true
      })
    }

    // Hide initially
    viewer!.style.visibility = 'hidden'
    viewer!.setAttribute('aria-hidden', 'true')
  }

  // Use only astro:page-load as it fires on initial load and navigation
  document.addEventListener('astro:page-load', initImageViewer)
</script>

<style>
  .image-viewer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease-in-out;
    background: var(--bg);
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    cursor: zoom-out;
  }

  .image-viewer.active {
    opacity: 1;
    visibility: visible;
  }

  .image-viewer img {
    min-width: 45rem;
    max-width: 60vw;
    max-height: 80vh;
    object-fit: contain;
    cursor: zoom-out;
  }

  .image-viewer-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: var(--bg);
    color: var(--text-primary);
    cursor: pointer;
    font-size: 1.5rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .image-viewer img {
      min-width: 100vw;
    }
  }

  body.image-viewer-open {
    overflow: hidden;
  }
</style>
